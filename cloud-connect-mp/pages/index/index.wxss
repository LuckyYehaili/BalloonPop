.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #080520 0%, #0d0b3a 50%, #08082a 100%);
}

.card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(167, 139, 250, 0.35);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
}

.env-id {
  font-size: 26rpx;
  color: #a78bfa;
  word-break: break-all;
}

.status {
  font-size: 30rpx;
  color: #ffffff;
  line-height: 1.5;
}

.status.loading {
  color: rgba(255, 255, 255, 0.65);
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #86efac;
  margin-bottom: 20rpx;
  font-weight: 600;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.row-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  flex-shrink: 0;
  margin-right: 24rpx;
}

.row-value {
  font-size: 26rpx;
  color: #ffffff;
  text-align: right;
  word-break: break-all;
}

.btn-retry {
  margin-top: 16rpx;
  background: linear-gradient(90deg, #f472b6, #a78bfa);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 30rpx;
}

.btn-retry[disabled] {
  opacity: 0.6;
}

.hint {
  display: block;
  margin-top: 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
}
